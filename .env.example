# Twilio (telephony + call recording)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_NUMBER=+13334445555          # the single number you use for ALL test calls

# The test line for this challenge — do not change
TARGET_NUMBER=+18054398008

# Gemini (Multimodal Live API + text analysis)
GEMINI_API_KEY=your_gemini_api_key

# Public HTTPS URL that tunnels to your local media-stream server
# (e.g. from `ngrok http 8765`) — Twilio needs this to open the media stream.
PUBLIC_BASE_URL=https://your-tunnel-subdomain.ngrok.io
